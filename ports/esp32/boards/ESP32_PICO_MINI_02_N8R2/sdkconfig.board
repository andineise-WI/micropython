# ESP32-PICO-MINI-02-N8R2 specific configuration

# Enable TWAI/CAN support
CONFIG_SOC_TWAI_SUPPORTED=y

# SPIRAM configuration (2MB QSPI PSRAM)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_TYPE_ESPPSRAM32=y
CONFIG_SPIRAM_SIZE_2MB=y
CONFIG_SPIRAM_SPEED_40M=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_CACHE_WORKAROUND=y
CONFIG_SPIRAM_BANKSWITCH_ENABLE=y

# Flash configuration (8MB)
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions-8MiBplus-ota.csv"

# Enable Bluetooth
CONFIG_BT_ENABLED=y

# TWAI specific settings
CONFIG_TWAI_ISR_IN_IRAM=y
CONFIG_TWAI_ERRATA_FIX_BUS_OFF_REC=y
CONFIG_TWAI_ERRATA_FIX_TX_INTR_LOST=y
CONFIG_TWAI_ERRATA_FIX_RX_FRAME_INVALID=y
CONFIG_TWAI_ERRATA_FIX_RX_FIFO_CORRUPT=y
